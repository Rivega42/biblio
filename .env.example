# irbis-web — схема конфигурации (БЕЗ значений). Реальные значения — в .env (gitignored) / секрет-менеджере прода.
# Источник модели: docs/CLAUDECODE_PROJECT_BRIEF.md §8, docs/design/ACCESS_MODEL_web-irbis.md.

# ── Сервер ИРБИС (нативный TCP-протокол) ─────────────────────────────
IRBIS_HOST=
IRBIS_PORT=6666
# лимит одновременных клиентов демо-сервера = 3 (беречь пул сессий)
IRBIS_MAX_POOL=

# ── Служебные креды по типу АРМа (бэкенд открывает сессию нужного типа под грант учётки) ──
# Тип АРМа в IC_reg: READER / CATALOG / BOOKLAND / COMPLECT / BOOKPROVD / ADMINISTRATOR
IRBIS_READER_USER=
IRBIS_READER_PASSWORD=
IRBIS_CATALOG_USER=
IRBIS_CATALOG_PASSWORD=
IRBIS_BOOKLAND_USER=
IRBIS_BOOKLAND_PASSWORD=
IRBIS_COMPLECT_USER=
IRBIS_COMPLECT_PASSWORD=
IRBIS_BOOKPROVD_USER=
IRBIS_BOOKPROVD_PASSWORD=
IRBIS_ADMINISTRATOR_USER=
IRBIS_ADMINISTRATOR_PASSWORD=

# ── Хранилище приложения (учётки сотрудников, гранты, роли, аудит) ───
DATABASE_URL=

# ── Прочее ───────────────────────────────────────────────────────────
APP_SECRET_KEY=
# путь к файловому хранилищу полных текстов/сканов (запись бинарей — не через протокол)
FULLTEXT_STORAGE_PATH=
