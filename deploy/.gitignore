# Deployment-local secrets + generated artifacts — NEVER commit.
# (Root .gitignore already covers .env / *.key / *.pem / *.db; this adds certs.)
.env
.env.*
!.env.example
!.env.demo.example
!.env.staging.example
# Ignore cert material but keep the certs/ mount dir (via its .gitkeep) tracked.
proxy/certs/*
!proxy/certs/.gitkeep
*.crt
*.key
*.pem
