# ─────────────────────────────────────────────────────────────────────────────
# Biblio STAGING — пример .env для не-прод стенда РЯДОМ с продом (см.
# docker-compose.staging.yml и docs/deploy/STAGING.md).
#   cp .env.staging.example .env.staging   # затем заполнить «СМЕНИТЬ_*»
# Запуск:
#   docker compose -p biblio-staging --env-file .env.staging \
#     -f docker-compose.yml -f docker-compose.staging.yml up -d --build
# ─────────────────────────────────────────────────────────────────────────────

# Отдельный compose-проект → свои контейнеры (biblio-staging-*) и тома
# (biblio-staging_pgdata/backend-data/backups), НЕ задевает прод (deploy-*).
COMPOSE_PROJECT_NAME=biblio-staging

# Порты ХОСТА — НЕ 80/443 (заняты боевым стендом).
HTTP_PORT=8080
HTTPS_PORT=8443

# Секреты СТЕНДА — СМЕНИТЬ; НЕ переиспользуй прод-секреты.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=СМЕНИТЬ_staging_pg_pass
POSTGRES_DB=biblio_staging
APP_SECRET=СМЕНИТЬ_staging_app_secret

# ИРБИС на staging ОТКЛЮЧЁН overlay'ем (IRBIS_HOST=""). Прод-данные недостижимы,
# запись в боевой ИРБИС/RDR невозможна. Каталог/поиск — из own-store:
IRBIS_PUBLIC_DBS=EK
OWN_SEARCH_DBS=EK
# Стенд сидируется КОПИЕЙ боевого /data/catalog.db (см. STAGING.md) — реалистичные
# данные для теста staff-АРМов; их правки остаются в томах стенда.

# Демо-вход читателя без обращения к RDR (стенд не ходит в боевой RDR).
# На стенде допустимо ослабить парольный режим (реальных RDR-учёток нет).
TEST_READER_TICKET=00000001
TEST_READER_PASS=СМЕНИТЬ_staging_reader_pass
REQUIRE_READER_PASSWORD=false
