# ─────────────────────────────────────────────────────────────────────────────
# Biblio — окружение ПУБЛИЧНОГО ДЕМО-СТЕНДА (профиль demo) — ШАБЛОН.
#
# Назначение: публичный демонстрационный экземпляр Biblio для проверки
# экспертами Минцифры при включении в Единый реестр росПО (issue #226).
# Сервер демо-стенда РАЗМЕЩАЕТСЯ В РФ (требование реестра — см.
# docs/deploy/DEMO_STAND.md и docs/legal/REGISTRATION_GUIDE.md §3.5).
#
# Скопировать в deploy/.env (НЕ .env.demo — overlay читает тот же .env, что и
# базовый стек) и заполнить. Все значения ниже — БЕЗОПАСНЫЕ дефолты для демо.
# Каждую строку с меткой «СМЕНИТЬ НА ПРОДЕ» нужно заменить реальным секретом
# до публикации демо-стенда в интернете. Файл deploy/.env в gitignore — НИКОГДА
# не коммитить заполненный .env.
#
#   cd deploy && cp .env.demo.example .env
#   docker compose -f docker-compose.yml -f docker-compose.demo.yml up -d --build
# ─────────────────────────────────────────────────────────────────────────────

# ── Маркер режима ────────────────────────────────────────────────────────────
# Демо-стенд: own-store (sqlite/PostgreSQL), БЕЗ живого ИРБИС и БЕЗ реальных ПДн.
APP_ENV=demo

# ── PostgreSQL (Access-стор: аккаунты/гранты/аудит/мультиаренда) ──────────────
POSTGRES_USER=postgres
# СМЕНИТЬ НА ПРОДЕ — для публичного демо задать длинный случайный пароль
# (openssl rand -hex 24). Дефолт ниже — только для локальной проверки overlay.
POSTGRES_PASSWORD=demo-change-me
POSTGRES_DB=irbis_access

# ── Бэкенд приложения ────────────────────────────────────────────────────────
# СМЕНИТЬ НА ПРОДЕ — подпись сессий/JWT. Сгенерировать:  openssl rand -hex 32
APP_SECRET=demo-insecure-secret-change-me

# ── Порты хоста для proxy (host:container) ───────────────────────────────────
# Публичный демо обычно слушает 80/443 за реальным доменом (demo.biblio.<ваш>.ru).
HTTP_PORT=80
HTTPS_PORT=443

# ── ИРБИС64: на демо-стенде ОТКЛЮЧЁН ─────────────────────────────────────────
# Демо НЕ ходит в живой ИРБИС: данные только из own-store (демо-каталог + демо-
# читатели без реальных ПДн). Переменные ИРБИС намеренно НЕ заданы — стек
# поднимается без них; OPAC-функции, требующие ИРБИС, на демо не используются.
# (Базовый docker-compose.yml имеет дефолты, overlay demo их не активирует.)

# ── Параметры демо-сида и сброса (читаются deploy/demo/*.sh) ──────────────────
# Слаг демо-арендатора (провижинится через python -m access.provision).
DEMO_TENANT_SLUG=demo
# Значения с пробелами берём в кавычки — файл сорсится через `. ./.env`.
DEMO_TENANT_NAME="Демо-библиотека Biblio"
# Логин/пароль демо-администратора. Пароль виден участникам проверки — это
# нормально для демо, но он НЕ должен совпадать с проднастройками.
DEMO_ADMIN_LOGIN=demo
DEMO_ADMIN_PASSWORD=demo
# Тарифный план демо-арендатора (включает соответствующие модули).
DEMO_PLAN=standard

# ── Ретенция бэкапов демо ────────────────────────────────────────────────────
# Сколько последних дампов pg_dump держать в томе backups (см. backup/pg_backup.sh).
DEMO_BACKUP_KEEP=7
