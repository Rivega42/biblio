# ─────────────────────────────────────────────────────────────────────────────
# Biblio deployment env — TEMPLATE (#207, epic #223).
#
# Copy to deploy/.env (gitignored) and fill in. Values below are SAFE DEV
# DEFAULTS. Every line marked "CHANGE IN PROD" MUST get a real secret before any
# non-local deployment. Never commit deploy/.env.
#
#   cd deploy && cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (Access store: accounts/grants/audit/tenancy) ─────────────────
POSTGRES_USER=postgres
# CHANGE IN PROD — dev placeholder only. Use a long random secret in prod.
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=irbis_access

# ── Backend app ──────────────────────────────────────────────────────────────
APP_ENV=prod
# CHANGE IN PROD — signs sessions/JWT. Generate, e.g.:  openssl rand -hex 32
APP_SECRET=dev-insecure-secret-change-me

# ── Proxy host ports (host:container) ────────────────────────────────────────
# Stack listens on https://localhost by default. Change if 80/443 are taken.
HTTP_PORT=80
HTTPS_PORT=443

# ── IRBIS64 native server (optional) ─────────────────────────────────────────
# Point at your live ИРБИС TCP server. If unset, OPAC features needing ИРБИС are
# unavailable but the stack still boots. On Docker Desktop, reach a server on the
# host machine via host.docker.internal instead of 127.0.0.1.
IRBIS_HOST=host.docker.internal
IRBIS_PORT=6666
IRBIS_USER=MASTER
# CHANGE IN PROD — service-account password for the ИРБИС session.
IRBIS_PASS=
IRBIS_WORKSTATION=A
IRBIS_DB_DEFAULT=IBIS
# Public (reader-visible) bibliographic DBs; deny-by-default for everything else.
IRBIS_PUBLIC_DBS=IBIS
