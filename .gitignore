# ── Working area (temp conversions, archive extractions) ─────────────
_work/

# ── Probe run output (raw capture; contains ANSI/CP1251 artifacts) ────
tools/irbis-probe/probe_results*.txt
tools/irbis-probe/*.bin

# ── Secrets — only schema in .env.example, never real values ─────────
.env
.env.*
!.env.example
*.secret
*.key
*.pem
secrets.*
# product INI files often carry creds (mail/LIBNET/IP) — never commit
*.ini

# ── Product source: binaries, DB data, images — not in repo ──────────
*.exe
*.dll
*.mst
*.xrf
*.ifp
*.l01
*.l02
*.n01
*.n02
*.cnt
*.ifs
*.fdt
*.ibf
*.bin
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.ico
*.wav
*.chm
*.hlp
*.doc
*.docx
*.rtf
*.ppt
*.rar
*.zip

# ── Code deps / build (future P0) ────────────────────────────────────
node_modules/
__pycache__/
*.pyc
dist/
build/
.venv/
venv/

# ── Allowed: derived doc text under docs/reference/ (protocol/manual)
!docs/reference/*.txt

tools/irbis-probe/*.txt
irbis-web/backend/*_results.txt
irbis-web/backend/tests/*_results.txt
# dev access store (accounts/grants/audit) — never commit
*.db
*.sqlite
*.sqlite3
