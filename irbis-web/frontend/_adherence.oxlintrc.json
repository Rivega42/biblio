        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ghost|outline|accent|solid)$/]",
        "message": "<IconButton> variant must be one of 'ghost' | 'outline' | 'accent' | 'solid'."
      },
