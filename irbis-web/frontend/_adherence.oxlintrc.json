{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/catalog/**",
              "components/cataloging/**",
              "components/feedback/**",
              "components/forms/**",
              "components/icon/**",
              "components/navigation/**",
              "components/viewer/**",
              "ui_kits/irbis-web/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:PT Sans|PT Serif|PT Mono))/i]",
        "message": "Font not provided by the design system. Available: PT Sans, PT Serif, PT Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|title|onClose|key|ref|className|style|children)$/]",
        "message": "<Alert> doesn't accept that prop. Declared props: variant, title, onClose."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:info|success|warning|error)$/]",
        "message": "<Alert> variant must be one of 'info' | 'success' | 'warning' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|count|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, count."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:neutral|accent|solid|success|warning|danger)$/]",
        "message": "<Badge> variant must be one of 'neutral' | 'accent' | 'solid' | 'success' | 'warning' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|iconLeft|iconRight|loading|block|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, iconLeft, iconRight, loading, block."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|indeterminate|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: label, indeterminate."
      },
      {
        "selector": "JSXOpeningElement[name.name='DatabaseOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|name|group|icon|description|count|stub|key|ref|className|style|children)$/]",
        "message": "<DatabaseOption> doesn't accept that prop. Declared props: id, name, group, icon, description, count, stub."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dialog'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|onClose|title|subtitle|footer|size|children|className|key|ref|className|style|children)$/]",
        "message": "<Dialog> doesn't accept that prop. Declared props: open, onClose, title, subtitle, footer, size, children, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dialog'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Dialog> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DictEntry'] > JSXAttribute > JSXIdentifier[name!=/^(?:term|count|code|key|ref|className|style|children)$/]",
        "message": "<DictEntry> doesn't accept that prop. Declared props: term, count, code."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|icon|title|description|hints|action|className|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: variant, icon, title, description, hints, action, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:neutral|error|locked)$/]",
        "message": "<EmptyState> variant must be one of 'neutral' | 'error' | 'locked'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ViewerFile'] > JSXAttribute > JSXIdentifier[name!=/^(?:field|label|kind|pages|tint|viewOnly|requiresAuth|priority|key|ref|className|style|children)$/]",
        "message": "<ViewerFile> doesn't accept that prop. Declared props: field, label, kind, pages, tint, viewOnly, requiresAuth, priority."
      },
      {
        "selector": "JSXOpeningElement[name.name='ViewerFile'] > JSXAttribute[name.name='field'] > Literal[value!=/^(?:955|951)$/]",
        "message": "<ViewerFile> field must be one of '955' | '951'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ViewerFile'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:pdf|image|djvu)$/]",
        "message": "<ViewerFile> kind must be one of 'pdf' | 'image' | 'djvu'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FilterChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|group|count|onRemove|onToggle|pressed|plain|key|ref|className|style|children)$/]",
        "message": "<FilterChip> doesn't accept that prop. Declared props: label, group, count, onRemove, onToggle, pressed, plain."
      },
      {
        "selector": "JSXOpeningElement[name.name='Holding'] > JSXAttribute > JSXIdentifier[name!=/^(?:location|inventory|status|key|ref|className|style|children)$/]",
        "message": "<Holding> doesn't accept that prop. Declared props: location, inventory, status."
      },
      {
        "selector": "JSXOpeningElement[name.name='Holding'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:available|issued|unknown)$/]",
        "message": "<Holding> status must be one of 'available' | 'issued' | 'unknown'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|label|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, strokeWidth, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute[name.name='name'] > Literal[value!=/^(?:search|x|chevron-down|chevron-up|chevron-left|chevron-right|chevrons-left|chevrons-right|arrow-left|arrow-right|check|plus|minus|filter|sliders|book|book-open|image|images|archive|calendar|calendar-star|user|log-in|log-out|bookmark|bookmark-check|check-circle|alert-triangle|alert-octagon|info|x-circle|clock|map-pin|external-link|download|share|link|copy|list|grid|eye|eye-off|type|accessibility|sun|file-text|newspaper|tag|rotate-ccw|menu|loader|map|layers|globe|help-circle|panel-left)$/]",
        "message": "<Icon> name must be one of 'search' | 'x' | 'chevron-down' | 'chevron-up' | 'chevron-left' | 'chevron-right' | 'chevrons-left' | 'chevrons-right' | 'arrow-left' | 'arrow-right' | 'check' | 'plus' | 'minus' | 'filter' | 'sliders' | 'book' | 'book-open' | 'image' | 'images' | 'archive' | 'calendar' | 'calendar-star' | 'user' | 'log-in' | 'log-out' | 'bookmark' | 'bookmark-check' | 'check-circle' | 'alert-triangle' | 'alert-octagon' | 'info' | 'x-circle' | 'clock' | 'map-pin' | 'external-link' | 'download' | 'share' | 'link' | 'copy' | 'list' | 'grid' | 'eye' | 'eye-off' | 'type' | 'accessibility' | 'sun' | 'file-text' | 'newspaper' | 'tag' | 'rotate-ccw' | 'menu' | 'loader' | 'map' | 'layers' | 'globe' | 'help-circle' | 'panel-left'."
