# Copy to irbis-web/.env (compose) or irbis-web/backend/.env (local). NEVER commit the real .env.
# --- IRBIS server (боевой) ---
IRBIS_HOST=127.0.0.1
IRBIS_PORT=6666
# Служебная учётка ИРБИС — РЕАЛЬНЫЕ значения только в .env (gitignored)
IRBIS_USER=
IRBIS_PASS=
IRBIS_WORKSTATION=A
IRBIS_DB_DEFAULT=IBIS
IRBIS_DB_MENU=1.&.dbnam1.mnu
IRBIS_TIMEOUT=8
# --- App ---
APP_HOST=127.0.0.1
APP_PORT=8080
APP_ENV=dev
APP_SECRET=                 # ключ подписи сессий (обязателен в prod)
ACCESS_DB=                  # путь к sqlite учёток/грантов; пусто = backend/access.db
# PG_DSN=postgresql://user:pass@host:5432/irbisweb   # когда Access переедет на Postgres
