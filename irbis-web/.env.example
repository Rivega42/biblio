# Copy to irbis-web/backend/.env and fill in. NEVER commit the real .env.
# IRBIS server (live)
IRBIS_HOST=127.0.0.1
IRBIS_PORT=6666
# P0 service account — REAL VALUES ONLY IN .env (gitignored), never here
IRBIS_USER=
IRBIS_PASS=
IRBIS_WORKSTATION=A
IRBIS_DB_DEFAULT=IBIS
IRBIS_TIMEOUT=8
# App
APP_HOST=127.0.0.1
APP_PORT=8080
APP_ENV=dev
# Later (access suite): per-ARM accounts, PG_DSN, APP_SECRET
